ANTHROPIC_API_KEY=sk-ant-...

# ─── Mail (usar SMTP del hospital o Mailtrap para desarrollo) ─────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.hospital.uncuyo.edu.ar   # reemplazar con el servidor SMTP del hospital
MAIL_PORT=587
MAIL_USERNAME=laboratorio@hospital.uncuyo.edu.ar
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=laboratorio@hospital.uncuyo.edu.ar
MAIL_FROM_NAME="Laboratorio HU UNCuyo"

# Para desarrollo/testing se puede usar Mailtrap:
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=<usuario_mailtrap>
# MAIL_PASSWORD=<password_mailtrap>
